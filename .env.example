# SQLite Configuration (local development)
DB_PATH=./data/app.db

# Cosmos DB Configuration (Azure production)
COSMOS_DB_ENDPOINT=https://vibe-coding-cosmos.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-db-key-here
COSMOS_DB_DATABASE=vibe_coding

# Node Environment
NODE_ENV=development

# Session Configuration
SESSION_SECRET=your-random-session-secret-here
SESSION_NAME=vibe_session
SESSION_TIMEOUT=3600000

# Authentication
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION=24h

# Apple OAuth Configuration (Set these if you want Apple Sign-in)
APPLE_TEAM_ID=your-apple-team-id
APPLE_CLIENT_ID=your-apple-client-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key-pem-format
APPLE_REDIRECT_URI=http://localhost:3000/auth/apple/callback

# Server Configuration
PORT=3000
HOST=localhost

# Logging
LOG_LEVEL=info

# Azure App Service Configuration (do not set locally)
# WEBSITE_INSTANCE_ID=1
# WEBSITE_AUTH_ENABLED=false
